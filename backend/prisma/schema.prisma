generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Idea {
  id                 String   @id @default(uuid())
  title              String
  description        String
  status             IdeaStatus @default(PENDING)
  problem            String?
  customer           String?
  market             String?
  competitors        Json?
  techStack          Json?
  riskLevel          RiskLevel?
  profitabilityScore Int?
  justification      String?
  rawAiResponse      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum IdeaStatus {
  PENDING
  COMPLETED
  FAILED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}
